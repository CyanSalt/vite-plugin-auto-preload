{
  "name": "vite-plugin-auto-preload",
  "version": "0.1.1",
  "description": "Vite plugin for adding preload resource hints in HTML",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint --fix './**/*.{js,ts}'",
    "lint:ci": "eslint --max-warnings 0 './**/*.{js,ts}'",
    "prepack": "tsdown",
    "release": "release-it"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CyanSalt/vite-plugin-auto-preload.git"
  },
  "keywords": [
    "vite",
    "plugin",
    "html"
  ],
  "author": "CyanSalt",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/CyanSalt/vite-plugin-auto-preload/issues"
  },
  "homepage": "https://github.com/CyanSalt/vite-plugin-auto-preload#readme",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.15.0",
      "onFail": "error"
    },
    "packageManager": [
      {
        "name": "pnpm",
        "version": "^11.0.0",
        "onFail": "error"
      },
      {
        "name": "npm",
        "onFail": "ignore"
      }
    ]
  },
  "peerDependencies": {
    "vite": ">=2.0.0"
  },
  "devDependencies": {
    "@cyansalt/eslint-config": "^4.6.0",
    "@cyansalt/tsconfig": "^3.0.2",
    "@release-it/conventional-changelog": "^11.0.0",
    "eslint": "^10.3.0",
    "release-it": "^20.0.1",
    "tsdown": "^0.22.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.11"
  },
  "dependencies": {
    "node-html-parser": "^7.1.0"
  }
}
